# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================

# Core Telegram API Credentials (Required)
API_ID=12345678
API_HASH=your_api_hash_from_my_telegram_org
BOT_TOKEN=your_bot_token_from_botfather
BOT_USERNAME=YourProtectionBot
BOT_NAME=Protection Bot

# Main Admin Configuration
OWNER_ID=123456789
OWNER_USERNAME=your_username
ADMIN_CHAT_ID=-1001234567890
SUPPORT_CHAT_ID=-1001234567891
LOG_CHANNEL_ID=-1001234567892

# Additional Admin User IDs (comma-separated)
ADMIN_IDS=123456789,987654321,456789123
SUDO_USERS=123456789,987654321

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database Settings
DATABASE_URL=sqlite:///data/bot.db
# For PostgreSQL: postgresql://user:password@localhost:5432/telegram_bot
# For MySQL: mysql://user:password@localhost:3306/telegram_bot

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
ERROR_LOG_FILE=logs/error.log

# =============================================================================
# ANTI-SPAM & MODERATION SETTINGS
# =============================================================================

# Rate Limiting (Default Values)
DEFAULT_MESSAGE_LIMIT=10
DEFAULT_MESSAGE_WINDOW=60
DEFAULT_FORWARD_LIMIT=5
DEFAULT_FORWARD_WINDOW=3600
DEFAULT_MENTION_LIMIT=5
DEFAULT_LINK_LIMIT=3

# Auto-Ban Thresholds
SPAM_SCORE_THRESHOLD=75
AUTO_BAN_SCORE=90
WARNING_THRESHOLD=3
RAID_THRESHOLD=10

# Content Filtering
ENABLE_LINK_FILTERING=true
ENABLE_MEDIA_FILTERING=false
ENABLE_LANGUAGE_DETECTION=true
ENABLE_NSFW_DETECTION=true
ENABLE_SCAM_DETECTION=true

# Time Limits (in seconds)
DEFAULT_MUTE_TIME=3600
DEFAULT_BAN_TIME=86400
MAX_MUTE_TIME=604800
MAX_BAN_TIME=2592000

# =============================================================================
# WELCOME & NOTIFICATION SETTINGS
# =============================================================================

# Default Messages
DEFAULT_WELCOME_MESSAGE=Welcome {mention} to {chat_title}! Please read the rules.
DEFAULT_GOODBYE_MESSAGE={mention} left {chat_title}
DEFAULT_RULES_MESSAGE=Please follow the group rules and be respectful.

# Notification Settings
ENABLE_WELCOME_MESSAGES=true
ENABLE_GOODBYE_MESSAGES=true
ENABLE_JOIN_NOTIFICATIONS=true
ENABLE_LEAVE_NOTIFICATIONS=false
ENABLE_PROMOTION_NOTIFICATIONS=true

# Message Cleanup
AUTO_DELETE_WELCOME_TIME=300
AUTO_DELETE_COMMANDS=true
COMMAND_DELETE_DELAY=30